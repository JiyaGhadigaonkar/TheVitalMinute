"assets": {
"cover": {
"id": "72d532e1-0247-4bf4-861f-1975c9dcdeed"
}
},
"attributes": ["327ebe56-ba17-4f3f-ade9-efffa6409b7f"],
"autoHeight": false,
"components": ["64e7e1bf-ec61-4d56-ba0e-1776054607ea"],
"content": "<p>I… I only had like… like, four cups. </p>",
"height": 421.0,
"outputs": ["11c94fa7-e53f-4648-a215-7070edc1615b"],
"theme": "purple",
"title": null,
"width": 340.987,
"x": 14300.0,
"y": 13720.0
},
