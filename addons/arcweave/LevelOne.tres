"assets": {
"cover": {
"id": "85e4f7b1-814f-43a4-b01d-8a1f2ab765ff"
}
},
"autoHeight": false,
"components": [],
"content": "<p>You step outside and notice it's warm despite being dark outside. Everyone sounds like they're having a good time at the party.</p>",
"height": 281.0,
"outputs": ["21e1cbf7-08be-40ea-a880-f046b7ddc0fd"],
"theme": "purple",
"title": null,
"width": 340.987,
