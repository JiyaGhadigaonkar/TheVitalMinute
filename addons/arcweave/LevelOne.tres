"assets": {
"cover": {
"id": "72d532e1-0247-4bf4-861f-1975c9dcdeed"
}
},
"autoHeight": true,
"components": ["62336e8f-f7ac-4d3d-804a-d9a5ce1c38fa"],
"content": "<p>You mix the tea into the hot water and give it to them.</p>",
"height": 399.0,
"outputs": ["4ba0b139-8518-4c72-a4e1-9217a41beb10"],
"theme": "purple",
"title": null,
"width": 301.0,
"x": 14960.0,
