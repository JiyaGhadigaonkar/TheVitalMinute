"assets": {
"cover": {
"id": "72d532e1-0247-4bf4-861f-1975c9dcdeed"
}
},
"attributes": ["b45a928a-ac69-4ed7-8daf-35adc28d6d7a"],
"autoHeight": false,
"components": ["64e7e1bf-ec61-4d56-ba0e-1776054607ea", "18b8d5a2-5e56-4dc7-9f9e-275ca98c3a70"],
"content": "<p>Onlooker (Liv): Her hands are cold… That’s not normal! We don't want her to get too cold!</p>",
"height": 441.0,
"outputs": ["c05e6ef3-98fc-4ec0-a4c2-26d7c021e5b6"],
"theme": "purple",
"title": null,
"width": 340.987,
