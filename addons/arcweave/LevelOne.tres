}
},
"autoHeight": true,
"components": ["64e7e1bf-ec61-4d56-ba0e-1776054607ea", "18b8d5a2-5e56-4dc7-9f9e-275ca98c3a70"],
"content": "<p><em>Now that you’re outside, you and Liv drop Vicky on the patio.</em></p>",
"height": 330.0,
"outputs": ["7487c508-af23-496b-946d-4529d1c9d19f"],
"theme": "purple",
"title": null,
"width": 301.0,
