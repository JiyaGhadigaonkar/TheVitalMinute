"content": "<p>You're with Frank and another friend. Frank has a cast on his foot. </p>",
"height": 241.0,
"outputs": ["d08d0672-f945-46ff-8919-6d26918800f9"],
"theme": "purple",
"title": "<p>Level 1 Start</p>",
"width": 300.994,
"x": 10140.0,
"y": 12080.0
},
