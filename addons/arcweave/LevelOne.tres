"components": ["62336e8f-f7ac-4d3d-804a-d9a5ce1c38fa", "64e7e1bf-ec61-4d56-ba0e-1776054607ea"],
"content": "<p><em>You give the person the hot tea.</em></p>",
"height": 401.0,
"outputs": ["8429bcd9-be6f-4d0a-a1ec-2f8da3b6988a"],
"theme": "purple",
"title": null,
"width": 340.987,
