}
},
"attributes": ["72267905-564a-4df1-83b4-f1d375e147e4"],
"autoHeight": false,
"components": [],
"content": "<p>Player: I’m going to call 911. We don’t know if their condition will worsen.</p>",
"height": 361.0,
"outputs": ["1fd14cf6-e22b-482e-b151-305e9f475860"],
