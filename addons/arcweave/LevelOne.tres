}
},
"attributes": ["fee8953e-a76b-4f61-af9c-649c39b7afee"],
"autoHeight": false,
"components": ["62336e8f-f7ac-4d3d-804a-d9a5ce1c38fa", "10e84276-ced6-484d-9f27-022fea26c2a2"],
"content": "<p>You give the person the hot water.</p>",
"height": 421.0,
"outputs": ["3ea72a9c-850a-45cc-8f4d-d9296ff8b7a2"],
"theme": "purple",
"title": null,
"width": 340.987,
"x": 15420.0,
"y": 12760.0
},
