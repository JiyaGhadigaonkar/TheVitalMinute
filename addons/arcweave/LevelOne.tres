"id": "72d532e1-0247-4bf4-861f-1975c9dcdeed"
}
},
"attributes": ["b1541422-32a1-45e5-9425-bff10a187de3"],
"autoHeight": false,
"components": ["62336e8f-f7ac-4d3d-804a-d9a5ce1c38fa", "10e84276-ced6-484d-9f27-022fea26c2a2"],
"content": "<p>I took the bus. Thank you. I’ll be fine.</p>",
"height": 401.0,
"outputs": ["21ac3dd8-b7ef-4349-8efd-d09c811d8173"],
"theme": "purple",
"title": null,
"width": 340.969,
