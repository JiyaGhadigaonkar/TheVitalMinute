"type": "image"
}
},
"autoHeight": true,
"components": ["894c2a71-952e-45c9-b55a-340794307a1d"],
"content": "<p>911-Operator: \"We’re sending a unit over right now. Please stay in place.</p>",
"height": 313.0,
"outputs": ["073c059a-4a19-4f34-ab06-931c46c4ce3c"],
"theme": "orange",
"title": null,
"width": 301.0,
