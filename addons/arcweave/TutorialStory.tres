"assets": {
"cover": {
"id": "7202d1ea-e81d-4292-8cd3-bd9cf6d5b1bd",
"type": "image"
}
},
"autoHeight": true,
"components": ["647349ca-9ebb-4d5f-b81e-500761ec1c5a"],
"content": "<p>Frank: Wait, before you do anything, mind the glass cup there. Make sure it's safe before you try to help. </p>",
"height": 334.0,
"outputs": ["635caecd-c6cb-4e6f-bfcb-8703d2e52278"],
"theme": "orange",
"title": "<p>Cozy Evening</p>",
"width": 301.0,
"x": 9660.0,
"y": 11660.0
},
