"type": "image"
}
},
"autoHeight": false,
"components": [],
"content": "<p><em>You investigate the knife wound. It’s fully through the foot. Blood is coming out of the top and on the floor underneath.</em></p>",
"height": 141.0,
"outputs": ["9a28d341-e45b-4a31-b5dd-75ac4a548eb4"],
"theme": "purple",
"title": null,
"width": 301.0,
