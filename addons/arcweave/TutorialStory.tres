"assets": {
"cover": {
"id": "7202d1ea-e81d-4292-8cd3-bd9cf6d5b1bd",
"type": "image"
}
},
"autoHeight": false,
"components": ["ad3d9699-c9ea-4bc0-aa9f-e9656ca0791c"],
"content": "<p>You: How’s your medical training going, anyhow?</p>",
"height": 341.0,
"outputs": ["e45bfe4c-1970-4cc7-99b0-0d13da51a307"],
"theme": "purple",
"title": null,
"width": 321.0,
