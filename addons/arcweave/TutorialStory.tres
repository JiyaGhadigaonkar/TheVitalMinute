"components": ["ad3d9699-c9ea-4bc0-aa9f-e9656ca0791c"],
"content": "<p>You: So, what are you cooking up right now?</p>",
"height": 321.0,
"outputs": ["1eb63a9e-bf9f-452d-9abf-224120165b59"],
"theme": "purple",
"title": null,
"width": 301.0,
