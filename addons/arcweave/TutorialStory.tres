},
"a8e8eee6-76df-4ed4-bbf0-8ac65ec5877b": {
"autoHeight": true,
"components": [],
"content": "<p>Based on your assessment, how will you help?</p>",
"height": 121.0,
"outputs": ["49bddfe3-d1ca-40a0-af66-ee19bd99c908", "3c1ced71-f1c2-48c8-b1e9-2624e22756c7"],
