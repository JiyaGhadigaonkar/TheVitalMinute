}
},
"autoHeight": true,
"components": ["647349ca-9ebb-4d5f-b81e-500761ec1c5a"],
"content": "<p><em>Gauze Wrapping microgame here.</em></p>",
"height": 121.0,
"outputs": ["674c1c5f-ed3a-46fb-9f63-0e1823202945", "965c85c4-15b2-4b52-8385-0047a5dfb6eb"],
"theme": "purple",
"title": null,
