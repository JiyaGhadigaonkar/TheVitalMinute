"assets": {
"cover": {
"id": "7202d1ea-e81d-4292-8cd3-bd9cf6d5b1bd",
"type": "image"
}
},
"autoHeight": true,
"components": ["647349ca-9ebb-4d5f-b81e-500761ec1c5a"],
"content": "<p>Frank: There should be plenty of medical supplies in there for this.</p>",
"height": 121.0,
"outputs": ["78ab6ff5-7a7f-4542-8568-630fb6d0ce58"],
"theme": "purple",
"title": null,
"width": 301.0,
"x": 11380.0,
"y": 9840.0
},
