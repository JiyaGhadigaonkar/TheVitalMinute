},
"attributes": ["a9f842c9-1780-4bb1-a3d8-a98449e7b1f5"],
"autoHeight": false,
"components": [],
"content": "<p><strong><em>Flavor Text</em></strong></p><p><em>Oh no. Your friends drove you here. You don’t know the address.</em></p>",
