"assets": {
"cover": {
"id": "7202d1ea-e81d-4292-8cd3-bd9cf6d5b1bd",
"type": "image"
}
},
"autoHeight": false,
"components": ["ad3d9699-c9ea-4bc0-aa9f-e9656ca0791c"],
"content": "<p>Frank: It’s been tough. They really try to make sure you’re ready for anything.</p>",
"height": 361.0,
"outputs": ["61a670e3-b125-4090-b420-5fa7930353e1"],
"theme": "purple",
"title": null,
"width": 381.0,
