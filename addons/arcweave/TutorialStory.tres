"type": "image"
}
},
"autoHeight": false,
"components": ["894c2a71-952e-45c9-b55a-340794307a1d"],
"content": "<p>911-Operator: \"This is 911, what is your emergency?\"</p>",
"height": 421.0,
"outputs": ["4e64ef52-638a-4461-9646-7885d4309069"],
"theme": "orange",
"title": null,
"width": 281.0,
"x": 8860.0,
"y": 13060.0
},
