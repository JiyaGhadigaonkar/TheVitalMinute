"attributes": ["c73c179e-3f27-4c2f-8fe6-3d40ba3efbba"],
"autoHeight": false,
"components": [],
"content": "<p><strong>Player: </strong>The address is 237 Stonecrest Street.</p><p></p><p></p>",
