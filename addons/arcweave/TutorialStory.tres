"assets": {
"cover": {
"id": "8bfe7259-406b-4c69-8bd6-f6d566686dec"
}
},
"autoHeight": false,
"components": [],
"content": "<p>Suddenly, one of the knives falls down and impales Frank's foot. You stand up with a jolt, knocking your water glass onto the ground.<br></p>",
"height": 361.0,
"outputs": ["5d41dc9d-4a64-43a6-96bc-7d422ccf13df"],
"theme": "purple",
"title": null,
"width": 341.0,
