"type": "image"
}
},
"autoHeight": false,
"components": ["647349ca-9ebb-4d5f-b81e-500761ec1c5a"],
"content": "<p>Frank: I need to keep pressure on the wound, but my arm’s getting sore.</p>",
"height": 321.0,
"outputs": ["dcaa2e2e-6efb-4e24-a38e-187142c39f8a"],
"theme": "purple",
"title": null,
"width": 341.0,
