"autoHeight": false,
"components": ["1f4389b8-e21a-4d12-84c7-c36cc0c50345"],
"content": "<p>Onlooker: Oh, I know them. They never drink. </p>",
"height": 341.0,
"outputs": ["f3981ca7-1fff-4c8e-8096-3bdbad908988"],
"theme": "purple",
