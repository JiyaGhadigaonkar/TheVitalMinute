"type": "image"
}
},
"autoHeight": false,
"components": ["ad3d9699-c9ea-4bc0-aa9f-e9656ca0791c"],
"content": "<p>[Name]: Is it really gory?</p>",
"height": 281.0,
"outputs": ["e618df92-b7b5-41a9-b666-44b6e9c3911f"],
"theme": "purple",
"title": null,
"width": 301.0,
