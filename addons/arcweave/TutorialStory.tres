"assets": {
"cover": {
"id": "7202d1ea-e81d-4292-8cd3-bd9cf6d5b1bd",
"type": "image"
}
},
"attributes": ["67967c0c-160e-43e3-9c5c-45e864ec628e"],
"autoHeight": false,
"components": [],
"content": "<p><strong>Player:</strong> I’ll check. One second.</p><p></p>",
"height": 361.0,
"outputs": ["40910bbc-0a20-4b91-8d9c-4647272ae560"],
"theme": "purple",
"title": null,
"width": 301.0,
