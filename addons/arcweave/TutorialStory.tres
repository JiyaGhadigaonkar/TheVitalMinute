"a8e9a04f-949d-430d-9de0-4ff88182353c": {
"autoHeight": false,
"components": [],
"content": "<p><em>They start coughing a lot. They look pale...</em></p>",
"height": 141.0,
"outputs": ["4b96a6fc-a3fc-4871-b174-ba0711fb96d1"],
"theme": "purple",
"title": null,
"width": 321.0,
