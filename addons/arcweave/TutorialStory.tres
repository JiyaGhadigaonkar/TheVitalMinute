"type": "image"
}
},
"autoHeight": true,
"components": ["647349ca-9ebb-4d5f-b81e-500761ec1c5a"],
"content": "<p>Frank<strong>: </strong>AH DAMN! OW!!</p>",
"height": 299.0,
"outputs": ["fd477598-e20d-4800-bec9-0737569f29eb"],
"theme": "cyan",
"title": "<p>Maya's Invitation</p>",
"width": 321.0,
