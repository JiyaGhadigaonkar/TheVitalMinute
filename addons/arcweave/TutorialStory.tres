"assets": {
"cover": {
"id": "7202d1ea-e81d-4292-8cd3-bd9cf6d5b1bd",
"type": "image"
}
},
"autoHeight": true,
"components": [],
"content": "<p>Frank: Wait, before you do anything, mind the glass there. I don't want us both to get stabbed in the foot.</p>",
"height": 406.0,
"outputs": ["635caecd-c6cb-4e6f-bfcb-8703d2e52278"],
"theme": "orange",
"title": "<p>Cozy Evening</p>",
