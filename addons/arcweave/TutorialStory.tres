"c10eb371-8ca2-4b34-bfa6-9c733a1ca628": {
"autoHeight": true,
"components": [],
"content": "<p><em>You check Vicky's pulse.</em></p><p><em>She doesn't have one.</em></p>",
"height": 134.0,
"outputs": ["eb6a091a-de8d-4e0d-8451-08a9e3a6f6ed"],
"theme": "purple",
"title": null,
"width": 301.0,
"x": 26920.0,
